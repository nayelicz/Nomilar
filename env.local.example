# .env.local — Variables de entorno para Avalanche
# Copia este archivo como .env.local y configura los valores

# ─── Red de Avalanche ────────────────────────────────────────────────────────
# "fuji" para testnet (desarrollo), "mainnet" para producción
NEXT_PUBLIC_AVALANCHE_ENV=fuji

# ─── Backend dispersor (si conservas el proxy de Next.js) ───────────────────
# Ya no necesitas DISPERSOR_API_URL si usas dispersión directa desde el cliente
# DISPERSOR_API_URL=http://127.0.0.1:3001
